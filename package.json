{
  "name": "@dinasor/mnemo-cli",
  "version": "0.0.9",
  "description": "Mnemo installer CLI for the current project folder.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DiNaSoR/Mnemo.git"
  },
  "homepage": "https://github.com/DiNaSoR/Mnemo#readme",
  "bugs": {
    "url": "https://github.com/DiNaSoR/Mnemo/issues"
  },
  "bin": {
    "mnemo": "bin/mnemo.js"
  },
  "files": [
    "bin/",
    "VERSION",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "scripts/memory/installer/**",
    "!scripts/memory/installer/**/__pycache__/**",
    "!scripts/memory/installer/**/*.pyc"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "sh ./tests/test-installer.sh",
    "test:help": "node bin/mnemo.js --help"
  },
  "engines": {
    "node": ">=18"
  }
}
